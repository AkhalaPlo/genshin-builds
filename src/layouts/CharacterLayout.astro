---
import '../styles/base.css';
import '../styles/build.css';
import '../styles/theme.css';
import Header from '../components/Header.astro';
import { t } from '../utils/i18n';

const { character, metadata, lang, locale } = Astro.props;
---

<html>
  <head>
    <meta charset="UTF-8" />
  </head>

  <body data-element={Astro.props.element}>
    <Header locale={locale} lang={lang} character={character} />
    <div class="page">
      <!-- CHARACTER HEADER CARD -->
      <div class="character-header">
        <img class="character-image" src={metadata?.image} />

        <h1 class="page-title">{character}</h1>

        {
          metadata?.last_updated && (
            <div class="last-updated">
              {t(locale, 'ui', 'Last Updated')}: {t(locale, 'ui', 'Version')}{' '}
              {metadata.last_updated}
            </div>
          )
        }
      </div>

      <slot />
    </div>
  </body>
</html>
