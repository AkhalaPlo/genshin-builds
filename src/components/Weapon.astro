---
import WeaponInfoPopover from './WeaponInfoPopover.astro';
import { t } from '../utils/i18n';
import type {
  WeaponPassiveText,
  WeaponPassiveValue,
} from '../utils/weapon-passive';
import { isFreeWeaponSource } from '../utils/weapon-source';

type WeaponItem = {
  id?: string;
  name: string;
  rarity: number;
  info?: {
    rarity: number;
    source?: string;
    passive?: WeaponPassiveText;
    r1?: WeaponPassiveValue[];
    r2?: WeaponPassiveValue[];
    r3?: WeaponPassiveValue[];
    r4?: WeaponPassiveValue[];
    r5?: WeaponPassiveValue[];
    substat?: string;
    level_1?: {
      base_attack?: number;
      substat_value?: string;
    };
    level_max?: {
      base_attack?: number;
      substat_value?: string;
    };
  };
  refinement?: number | string;
  note?: string;
  noteId?: string;
};

type WeaponRank = {
  items: WeaponItem[];
};

type WeaponRecommendations = {
  weapons: WeaponRank[];
  conditional?: WeaponItem[];
};

const {
  weapons,
  locale,
  lang = 'en',
} = Astro.props as {
  weapons: WeaponRecommendations;
  locale: any;
  lang?: string;
};

/**
 * Formats a refinement value for display beside a weapon name.
 *
 * @param refinement Optional weapon refinement value.
 * @returns Formatted refinement suffix.
 */
const formatRefinement = (refinement?: number | string) =>
  refinement ? ` [R${refinement}]` : '';

const hasNoteMarker = (item: WeaponItem) => item.noteId || item.note;
const isFreeWeapon = (item: WeaponItem) =>
  isFreeWeaponSource(item.info?.source);
const conditionalWeapons = weapons.conditional ?? [];
const rankedWeaponGroups = weapons.weapons.map(
  (position: WeaponRank, index: number) => ({
    rank: index + 1,
    rows: position.items.map((weapon, weaponIndex) => ({
      weapon,
      isAlternative: weaponIndex > 0,
    })),
  }),
);
const hasFreeWeapon = rankedWeaponGroups.some((position) =>
  position.rows.some(({ weapon }) => isFreeWeapon(weapon)),
) || conditionalWeapons.some((weapon) => isFreeWeapon(weapon));
---

<div class="card recommendation-card weapon-card">
  <h2>{t(locale, 'ui', 'Weapons')}</h2>

  <div class="recommendation-card-body">
        {
      hasFreeWeapon && (
        <p class="free-weapon-note">
          <span class="free-weapon-note-mark" aria-hidden="true" />
          {t(locale, 'ui', 'Highlighted weapons are free options.')}
        </p>
      )
    }
    {
      /* Ranked weapon groups. Extra items in one rank render as approximate ties. */
    }
    <div class="rank-list">
      {
        rankedWeaponGroups.map((position) => (
          <div class="rank-group">
            {position.rows.map(({ weapon, isAlternative }) => {
              const isFree = isFreeWeapon(weapon);
              const content = (
                <span class="inline-info-label">
                  <WeaponInfoPopover
                    weapon={weapon}
                    locale={locale}
                    lang={lang}
                    noteId={weapon.noteId}
                    hasNote={Boolean(hasNoteMarker(weapon))}
                  />
                  <span class="bold">
                    ({weapon.rarity}
                    {'\u2605'}){formatRefinement(weapon.refinement)}
                  </span>
                </span>
              );

              return isAlternative ? (
                <div class={`rank-row alt${isFree ? ' is-free-weapon' : ''}`}>
                  <span class="rank-approx">&asymp;</span>
                  <span class="rank-content">{content}</span>
                </div>
              ) : (
                <div class={`rank-row${isFree ? ' is-free-weapon' : ''}`}>
                  <strong class="rank-number">{position.rank}</strong>
                  <span class="rank-content">{content}</span>
                </div>
              );
            })}
          </div>
        ))
      }
    </div>

    {/* Optional unranked recommendations that depend on build notes. */}
    {
      conditionalWeapons.length > 0 && (
        <div class="conditional-list">
          <div class="conditional-heading">
            {t(locale, 'ui', 'Conditional (See Notes):')}
          </div>

          <div class="rank-list">
            {conditionalWeapons.map((weapon: WeaponItem) => {
              const isFree = isFreeWeapon(weapon);

              return (
                <div
                  class={`rank-row conditional-row${isFree ? ' is-free-weapon' : ''}`}
                >
                  <span class="rank-marker" aria-hidden="true" />
                  <span class="rank-content">
                    <span class="inline-info-label">
                      <WeaponInfoPopover
                        weapon={weapon}
                        locale={locale}
                        lang={lang}
                        noteId={weapon.noteId}
                        hasNote={Boolean(hasNoteMarker(weapon))}
                      />
                      <span class="bold">
                        ({weapon.rarity}
                        {'\u2605'}){formatRefinement(weapon.refinement)}
                      </span>
                    </span>
                  </span>
                </div>
              );
            })}
          </div>
        </div>
      )
    }
  </div>
</div>

<script>
  import '../scripts/info-popover';
</script>
