---
import { t } from '../utils/i18n';
import ArtifactSetItems from './ArtifactSetItems.astro';

type ArtifactSetItem = {
  name: string;
  pieces: number;
  note?: string;
  noteId?: string;
  id?: string;
  info?: {
    rarity: number;
    '1p'?: { en?: string; [lang: string]: string | undefined };
    '2p'?: { en?: string; [lang: string]: string | undefined };
    '4p'?: { en?: string; [lang: string]: string | undefined };
  };
};

type ArtifactSetGroup = {
  items?: ArtifactSetItem[];
  choose?: boolean;
  choices?: { items: ArtifactSetItem[] }[];
};

const {
  group,
  locale,
  lang = 'en',
} = Astro.props as {
  group: ArtifactSetGroup;
  locale: any;
  lang?: string;
};

const groupItems = group.items ?? [];
---

{
  /* Choose-two groups render extra items as `.alt` rows to match approximate ties. */
}
{
  group.choose ? (
    <>
      {groupItems[0] && (
        <ArtifactSetItems items={[groupItems[0]]} locale={locale} lang={lang} />
      )}
      {groupItems.slice(1).map((item) => (
        <div class="alt">
          <ArtifactSetItems items={[item]} locale={locale} lang={lang} />
        </div>
      ))}
      <div class="alt bold">{t(locale, 'ui', 'Choose Two')}</div>
    </>
  ) : group.choices ? (
    <>
      {group.choices.map((choice, choiceIndex) =>
        choiceIndex === 0 ? (
          <ArtifactSetItems
            items={choice.items}
            locale={locale}
            lang={lang}
            chooseOne={true}
          />
        ) : (
          <div class="alt">
            &{' '}
            <ArtifactSetItems
              items={choice.items}
              locale={locale}
              lang={lang}
              chooseOne={true}
            />
          </div>
        ),
      )}
    </>
  ) : (
    <ArtifactSetItems items={groupItems} locale={locale} lang={lang} />
  )
}
