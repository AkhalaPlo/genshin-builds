---
type Props = {
  label: string;
  noteId?: string;
  hasNote?: boolean;
  emphasized?: boolean;
};

const {
  label,
  noteId,
  hasNote = false,
  emphasized = false,
} = Astro.props as Props;
const showMarker = Boolean(noteId || hasNote);
const trimmedLabel = label.trimEnd();
const trailingSpace = label.slice(trimmedLabel.length);
const labelMatch = showMarker ? trimmedLabel.match(/^([\s\S]*?)(\S+)$/u) : null;
const labelPrefix = labelMatch?.[1] ?? '';
const labelTail = labelMatch?.[2] ?? trimmedLabel;
const className = emphasized
  ? 'inline-note-label inline-note-label-emphasized'
  : 'inline-note-label';
---

{
  showMarker ? (
    <span class={className}>
      {labelPrefix}
      <span class="note-tail">
        {labelTail}
        {noteId ? (
          <a class="note-link" href={`#${noteId}`}>
            ⓘ
          </a>
        ) : (
          <span class="note-marker-text">ⓘ</span>
        )}
      </span>
      {trailingSpace}
    </span>
  ) : emphasized ? (
    <span class={className}>{label}</span>
  ) : (
    <>{label}</>
  )
}
